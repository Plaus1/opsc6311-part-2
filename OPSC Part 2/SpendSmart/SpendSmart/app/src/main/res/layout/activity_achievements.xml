<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/green_primary"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/yellow_accent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Your Achievements"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvTotalBadges"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Badges: 0 🏅"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvCurrentStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Streak: 0 🔥"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Streak Badges -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Streak Badges"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvStreakBadge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 7-Day Streak (0/7 days)"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/progressStreak7"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progressTint="@color/orange_warning"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvMonthStreakBadge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 30-Day Streak (0/30 days)"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/progressStreak30"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progressTint="@color/red_error"
                        android:layout_marginBottom="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Expense Badges -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Expense Milestones"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvFirstExpense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 Log your first expense"
                        android:textSize="15sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvTenExpenses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 Log 10 expenses (0/10)"
                        android:textSize="15sp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvFiftyExpenses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 Log 50 expenses (0/50)"
                        android:textSize="15sp"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/progressExpenses"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progressTint="@color/green_primary"
                        android:layout_marginBottom="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Category Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷️ Organisation Badges"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvCategoryBadge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔒 Create 5 categories (0/5)"
                        android:textSize="15sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
